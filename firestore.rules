rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny: no public read/write access.
    // Content (partners, promo slides, journey steps) is served via Sanity CMS,
    // not Firestore. Lock everything down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
